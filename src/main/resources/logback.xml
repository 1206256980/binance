<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 格式：时间 [级别] [类名.方法名:行号] 消息 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%level] [%logger{20}.%method:%line] %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 关掉 Spark / Jetty 内部的大量无关日志，只显示 WARN 以上 -->
    <logger name="org.eclipse.jetty" level="WARN"/>
    <logger name="spark" level="WARN"/>

    <!-- 业务日志：INFO 以上全部输出 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
